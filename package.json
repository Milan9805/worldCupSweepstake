{
  "name": "sweepstake",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:lambda": "node scripts/build-lambda.js",
    "test": "npm run test --workspaces --if-present",
    "posttest": "npm run lint",
    "test:components": "npm run test --workspace=packages/frontend",
    "test:e2e": "npm run test:e2e --workspace=packages/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/frontend",
    "seed": "npx ts-node --project scripts/tsconfig.json scripts/seed.ts",
    "wait-for-dynamo": "until curl -s http://localhost:8000 > /dev/null 2>&1; do sleep 1; done",
    "wait-for-s3": "until curl -s http://localhost:4566/_localstack/health > /dev/null 2>&1; do sleep 1; done",
    "setup-s3": "npx ts-node --project scripts/tsconfig.json scripts/setup-s3.ts",
    "api:local": "npm run dev --workspace=packages/api",
    "start:local": "docker-compose up -d && npm run wait-for-dynamo && npm run wait-for-s3 && npm run seed && npm run setup-s3 && (npm run api:local &) && sleep 2 && npm run dev",
    "stop": "lsof -ti:3001 -ti:3000 | xargs kill -9 2>/dev/null; docker-compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3"
  }
}
